# ─── thirdweb ─────────────────────────────────────────────────────────────────
VITE_THIRDWEB_CLIENT_ID=821adf6c06a2e527b87f32dd6c49e5b9

# Thirdweb Engine Relayer (gasless tx).
# - Relayer wallet ADDRESS is public (on-chain data) → safe in client bundle.
# - Relayer API KEY is a SECRET. It must NEVER appear in client bundle. Frontend
#   calls a Supabase Edge Function / cf-worker which holds the key server-side
#   and forwards signed requests to Thirdweb Engine.
VITE_THIRDWEB_RELAYER_ADDRESS=0x60b2aba282073b06d4914e8b71050443b82c6603
# THIRDWEB_RELAYER_KEY=  ← stored as GitHub Secret + Supabase Edge Function secret. NO VITE_ prefix.

# ─── Chain（主网） ───────────────────────────────────────────────────────────
#   bsc_mainnet  (chainId 56)
#   bsc_testnet  (chainId 97)
VITE_RUNE_CHAIN=bsc_mainnet
VITE_RUNE_COMMUNITY_MAINNET=
VITE_RUNE_NODE_PRESELL_MAINNET=

# ─── OpenRouter（AI 信号源用） ─────────────────────────────────────────────────
VITE_OPENROUTER_API=

